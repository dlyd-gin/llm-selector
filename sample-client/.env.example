# =============================================================================
# Sample Client - Environment Configuration Template
# =============================================================================
#
# This is a template for your .env file. Copy this file and rename it to .env
# then replace the placeholder values with your actual API keys.
#
# IMPORTANT: Never commit your actual .env file with real API keys!
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI Configuration
# -----------------------------------------------------------------------------
# Your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_APIKEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration (Multiple Regions for Failover)
# -----------------------------------------------------------------------------
# Azure OpenAI endpoint URLs and API keys for different regions

# Australia East
AZURE_OPENAI_API_BASE_AUEAST=https://your-resource.openai.azure.com/
AZURE_OPENAI_APIKEY_AUEAST=your-azure-api-key-aueast-here

# North Central US
AZURE_OPENAI_API_BASE_NORTHCENTRALUS=https://your-resource.openai.azure.com/
AZURE_OPENAI_APIKEY_NORTHCENTRALUS=your-azure-api-key-northcentralus-here

# South Central US
AZURE_OPENAI_API_BASE_SOUTHCENTRALUS=https://your-resource.openai.azure.com/
AZURE_OPENAI_APIKEY_SOUTHCENTRALUS=your-azure-api-key-southcentralus-here


